{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": ["config:recommended", ":semanticCommitsDisabled"],
  "schedule": ["monthly"],
  "reviewers": ["strangelookingnerd"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "groupName": "Angular",
      "matchPackageNames": ["@angular/{/,}**"]
    },
    {
      "groupName": "tsParticles",
      "matchPackageNames": ["@tsparticles/{/,}**"]
    }
  ]
}
