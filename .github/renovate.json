{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": ["config:recommended", ":semanticCommitsDisabled"],
  "schedule": ["monthly"],
  "reviewers": ["strangelookingnerd"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchPackagePrefixes": ["@angular/"],
      "groupName": "Angular"
    },
    {
      "matchPackagePrefixes": ["@tsparticles/"],
      "groupName": "tsParticles"
    }
  ]
}
